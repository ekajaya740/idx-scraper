# IDX Scraper — configuration overrides
# Copy to .env and uncomment what you need.

# API page size (default: 100)
# PAGE_SIZE=100

# Download timeout in seconds (default: 120)
# DOWNLOAD_TIMEOUT=120

# Output directory (default: download)
# DOWNLOAD_DIR=download

# Jitter ranges in seconds — min and max delay between requests
# These make the scraper behave more like a human browser
# DELAY_PAGE_MIN=1.0
# DELAY_PAGE_MAX=3.0
# DELAY_COMPANY_MIN=0.5
# DELAY_COMPANY_MAX=2.0
# DELAY_ATTACHMENT_MIN=0.2
# DELAY_ATTACHMENT_MAX=0.8